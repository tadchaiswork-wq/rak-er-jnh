rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && (myRole() == 'admin' || myRole() == 'superadmin');
    }

    // ---- ทะเบียนผู้ใช้ ----
    match /users/{userId} {
      allow read: if isSignedIn();
      // สมัครสมาชิกได้ด้วยตนเอง (สร้างเอกสารของตัวเอง)
      allow create: if isSignedIn() && request.auth.uid == userId;
      // แก้ไข/ลบ: เจ้าของ หรือ admin
      allow update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // ---- การเข้าเวร (สแกน barcode) ----
    match /checkins/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---- รายงานเพื่อนร่วมงาน ----
    match /reports/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.fromUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ---- ชื่นชมเพื่อนร่วมงาน ----
    match /appreciations/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.fromUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
